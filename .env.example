# Enterprise Distributed Task Scheduler — Environment Configuration

# Database
DATABASE_URL=postgres://postgres:yourpassword@localhost:5432/task_scheduler?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379

# API Server
API_PORT=8080

# Scheduler
SCHEDULER_TICK_SECONDS=10

# Retry Policy
MAX_RETRIES=3
RETRY_BASE_DELAY_MS=1000

# Worker Concurrency (per executor type)
WORKER_EMAIL_CONCURRENCY=3
WORKER_WEBHOOK_CONCURRENCY=5
WORKER_PDF_CONCURRENCY=2
